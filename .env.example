# ─────────────────────────────────────────
#  Smart Media Fetcher — Environment Config
# ─────────────────────────────────────────

# App
APP_NAME=SmartMediaFetcher
APP_ENV=production          # development | production
DEBUG=false
SECRET_KEY=change-this-to-a-very-long-random-secret-key-minimum-32-chars
API_V1_PREFIX=/api/v1

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL)
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=smf_user
POSTGRES_PASSWORD=change-this-strong-db-password
POSTGRES_DB=smart_media_fetcher
DATABASE_URL=postgresql+asyncpg://smf_user:change-this-strong-db-password@db:5432/smart_media_fetcher

# Redis
REDIS_URL=redis://redis:6379/0
CACHE_TTL_SECONDS=300

# Celery
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# JWT
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# File handling
MAX_FILE_SIZE_MB=500
TEMP_DIR=/tmp/smf_downloads
AUTO_DELETE_TEMP_MINUTES=30

# Rate limiting
RATE_LIMIT_REQUESTS_PER_MINUTE=30
RATE_LIMIT_BURST=10

# External request settings
HTTP_TIMEOUT_SECONDS=30
MAX_REDIRECTS=5

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/smf/app.log

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost,https://yourdomain.com

# FFmpeg path
FFMPEG_PATH=/usr/bin/ffmpeg
